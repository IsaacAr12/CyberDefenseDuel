{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run JavaFX App",
      "request": "launch",
      "mainClass": "client.MainApp",
      "cwd": "${workspaceFolder}",
      "vmArgs": "--module-path \"${workspaceFolder}\\lib\" --add-modules javafx.controls,javafx.fxml",
      "classPaths": [
        "${workspaceFolder}\\bin",
        "${workspaceFolder}\\lib\\*"
      ]
    }
  ]
}